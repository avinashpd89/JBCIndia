{
  "name": "jbc-india-server",
  "version": "1.0.0",
  "description": "Backend for JBC India",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "kill-port": "for /f \"tokens=5\" %a in ('netstat -ano ^| findstr :5001') do taskkill /F /PID %a 2>nul & nodemon src/server.js"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1045.0",
    "@aws-sdk/client-dynamodb": "^3.0.0",
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/lib-dynamodb": "^3.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.6.2",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
